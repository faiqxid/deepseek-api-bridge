# Port server API
PORT=3000

# Kunci admin untuk endpoint manajemen akun
# Wajib diisi agar endpoint /admin/accounts dapat digunakan
ADMIN_API_KEY=ganti_dengan_kunci_yang_kuat

# Akun DeepSeek diisi melalui file accounts.txt
# Format tiap baris: email:password

# Opsional: TTL token cache dalam milidetik (default 1 jam)
# TOKEN_TTL_MS=3600000

# Opsional: model default jika request tidak menyebut model
# DEFAULT_MODEL=deepseek-chat

# Opsional: level log (debug, info, warn, error, silent)
# LOG_LEVEL=info

# Opsional: cek ADMIN_API_KEY saat startup (false untuk skip warning)
# CHECK_ADMIN_ON_START=true

# Opsional: Enable tool calling support untuk Hermes Agent
# TOOL_CALLING_ENABLED=true

# Opsional: Tool call parsing mode (strict|lenient)
# TOOL_CALL_PARSING_MODE=lenient

# Opsional: Max tool calls per request (0 = unlimited)
# MAX_TOOL_CALLS=10

# Opsional: Tool call timeout dalam milidetik
# TOOL_CALL_TIMEOUT_MS=30000

# Opsional: Enable Claude/Gemini compatible endpoints
# ENABLE_CLAUDE_COMPATIBLE=true
# ENABLE_GEMINI_COMPATIBLE=true

# Opsional: Enable additional model aliases untuk Hermes Agent
# ENABLE_MODEL_ALIASES=true
